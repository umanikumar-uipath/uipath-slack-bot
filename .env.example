# ── Slack ─────────────────────────────────────────────────────────────────────
# api.slack.com/apps → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token

# api.slack.com/apps → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=your-signing-secret

# api.slack.com/apps → Your App → Basic Information → App-Level Tokens → Create Token
# Scopes needed: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# ── UiPath ────────────────────────────────────────────────────────────────────
# cloud.uipath.com → User icon → Preferences → Personal Access Tokens → Create Token
UIPATH_PAT=your-personal-access-token

# The part of cloud.uipath.com/<org-name>
UIPATH_ORG_NAME=your-org-name

# The tenant name shown in the UiPath Cloud URL
UIPATH_TENANT_NAME=your-tenant-name
